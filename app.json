{
  "expo": {
    "name": "leyapp",
    "slug": "leyapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "leyapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.arsenysemina.leyapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.arsenysemina.leyapp"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {}
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bfb1f095-2455-4ba8-8dd0-eac6aabb8eef"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bfb1f095-2455-4ba8-8dd0-eac6aabb8eef"
    }
  }
}
